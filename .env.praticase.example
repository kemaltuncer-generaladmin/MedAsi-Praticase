SUPABASE_URL=https://your-supabase-project.example.com
FLUTTER_SUPABASE_URL=https://your-supabase-project.example.com
SUPABASE_ANON_KEY=replace-with-public-anon-key
AUTH_REDIRECT_URL=https://praticase.medasi.com.tr/auth/callback

# Supabase Edge Function secrets only. Do not expose these to Flutter builds.
# Set these with `supabase secrets set`, not in committed files.
PRATICASE_ALLOWED_ORIGINS=https://praticase.medasi.com.tr,https://www.praticase.medasi.com.tr
VERTEX_AI_LOCATION=global
VERTEX_AI_PROJECT_ID=your-google-cloud-project-id
VERTEX_AI_HISTORY_MODEL=gemini-2.5-flash
VERTEX_AI_TTS_MODEL=gemini-2.5-flash-tts
VERTEX_AI_EVALUATION_MODEL=gemini-3.5-flash
GOOGLE_VERTEX_SERVICE_ACCOUNT_JSON_BASE64=base64-encoded-service-account-json

# App Store Server API secrets for `praticase-storekit-verify` only.
# Never ship the private key or certificates in a Flutter build.
PRATICASE_APP_STORE_BUNDLE_ID=com.medasi.praticase
PRATICASE_APP_STORE_APP_ID=replace-with-numeric-app-store-id
PRATICASE_APP_STORE_KEY_ID=replace-with-in-app-purchase-key-id
PRATICASE_APP_STORE_ISSUER_ID=replace-with-app-store-issuer-id
PRATICASE_APP_STORE_PRIVATE_KEY_BASE64=base64-encoded-p8-private-key

# Optional trust-anchor override; official Apple roots are included in code.
PRATICASE_APPLE_ROOT_CA_CERTIFICATES_BASE64=comma-separated-base64-der-apple-root-certificates
